# Copia este archivo como terraform.tfvars y ajusta si es necesario.

resource_group_name = "johan"
location             = "centralus"

vnet_name = "vnet-ha"

# Una app subnet por instancia: VM 1 -> az1, VM 2 -> az2
app_subnet_names = ["snet-app-az1", "snet-app-az2"]

web_instance_count = 2

prefix               = "appgw-web"
vm_size              = "Standard_B1s"
admin_username       = "azureuser"
ssh_public_key_path  = "~/.ssh/id_rsa.pub"

# Cambiar a true si queres WAF_v2 en vez de Standard_v2
enable_waf = false

tags = {
  environment = "production"
  project     = "ha-vnet"
  managed_by  = "terraform"
}
